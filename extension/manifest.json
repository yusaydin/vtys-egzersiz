{
  "manifest_version": 3,
  "name": "VFS Global Randevu Asistanı",
  "version": "1.0",
  "description": "VFS Global randevu sayfalarında otomatik form doldurur, slotları izler, alarm çalar ve Telegram'a bildirim gönderir.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://*.vfsglobal.com/*",
    "https://api.telegram.org/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.vfsglobal.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
